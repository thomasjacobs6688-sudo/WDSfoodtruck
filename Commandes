                let absHtml = `
                    <div class="absents-box">
                        <div class="absents-title">⚠️ Pas de commande le ${periodFilter} : <span>Total : ${nonVotantsStrings.length}</span></div>
                        <ul class="absents-list">
                `;
                nonVotantsStrings.forEach(n => { absHtml += `<li>❌ ${n}</li>`; });
                absHtml += `</ul></div>`;
                absentsContainer.innerHTML = absHtml;
            } else {
                absentsContainer.innerHTML = `<div class="absents-box" style="background:#f0fdf4; border-color:#bbf7d0; color:#166534;"><div class="absents-title" style="color:#166534;">🎉 Tout le monde a commandé !</div></div>`;
            }
        } else if (personFilter === "Tous") {
            absentsContainer.innerHTML = `<div class="absents-box" style="background: #e2e8f0; border-color: #cbd5e1; color: #475569;"><div class="absents-title" style="color: #475569;">💡 Mode d'emploi</div><p style="font-size:0.85rem; font-style:italic;">Sélectionnez un jour spécifique pour lister les absents.</p></div>`;
        } else {
            absentsContainer.innerHTML = `<div class="absents-box" style="background: #e2e8f0; border-color: #cbd5e1; color: #475569;"><div class="absents-title" style="color: #475569;">🎯 Focus ciblé</div><p style="font-size:0.85rem; font-style:italic;">Recherche nominative active sur un seul profil.</p></div>`;
        }

        participantsList.forEach(p => {
            let nameClean = p.name.trim();
            let roleClean = p.role;
            if(nameClean === "") return;

            if (groupFilter !== "Tous" && roleClean !== groupFilter) return;
            if (personFilter !== "Tous" && nameClean !== personFilter) return;

            let filteredOrders = appVotes.filter(v => {
                if (v.name.toLowerCase() !== nameClean.toLowerCase()) return false;
                if (periodFilter !== "Totalite" && v.day !== periodFilter) return false;
                if (periodFilter !== "Totalite" && serviceFilter !== "Tous" && v.period !== serviceFilter) return false;
                return true;
            });

            let trackingText = "";
            let totalPrice = 0;

            if (filteredOrders.length === 0) {
                trackingText = `<span style="color:#94a3b8; font-style:italic;">Aucune commande sur cette période.</span>`;
            } else {
                let listStrings = filteredOrders.map(o => {
                    let dataPlat = helperObtenirPrixEtConfigPlat(o.day, o.period, o.mealName);
                    totalPrice += dataPlat.prix;
                    let extraRemarks = o.remarks ? ` <small style="color:var(--warning-text); font-weight:600;">(⚠️ ${o.remarks})</small>` : '';
                    return `<b>${o.day}</b>-${o.period[0]} <span style="color:#64748b;">[${dataPlat.type}]</span> ${o.mealName}${extraRemarks}`;
                });
                trackingText = listStrings.join(' / ');
            }

            let roleBadgeClass = roleClean === "Staff" ? "badge-staff" : "badge-team";

            let row = document.createElement('tr');
            row.innerHTML = `
                <td>
                    <strong>${nameClean}</strong>
                    <span class="badge-role ${roleBadgeClass}">${roleClean}</span>
                </td>
                <td>${trackingText}</td>
                <td class="text-right"><span class="badge-total">${totalPrice.toFixed(2)} €</span></td>
            `;
            tableBody.appendChild(row);
        });
    }

    function generatePrintSheets() {
        const orgDay = document.getElementById('orgDaySelect').value;
        const orgPeriod = document.getElementById('orgPeriodSelect').value;
        const printableArea = document.getElementById('printableArea');
        printableArea.innerHTML = '';
        const currentConfig = foodTrucksData[orgDay][orgPeriod];
        if(!currentConfig || !currentConfig.trucks) return;

        currentConfig.trucks.forEach(truck => {
            let sheetHtml = `<div class="print-sheet"><div class="print-header"><div class="print-truck-title">🎪 FOOD TRUCK : ${truck.name}</div><div class="print-day-sub">🗓️ ${orgDay} — Service du ${orgPeriod}</div></div>`;
            currentConfig.hours.forEach((serviceHour) => {
                const currentOrders = appVotes.filter(v => v.day === orgDay && v.time === serviceHour && v.truckName === truck.name);
                sheetHtml += `<div class="print-service-section"><div class="print-service-title"><span>📌 SERVICE DE ${serviceHour}</span><span>Total : ${currentOrders.length} article(s)</span></div>`;
                if(currentOrders.length === 0) {
                    sheetHtml += `<p style="color:#94a3b8; font-style:italic; padding:0.5rem 0;">Aucune commande pour ce service.</p>`;
                } else {
                    ["Entrée", "Plat", "Dessert"].forEach(typeLabel => {
                        const mealsOfThisType = truck.meals.filter(m => (m.type || "Plat") === typeLabel);
                        let hasOrdersInCat = mealsOfThisType.some(m => currentOrders.some(o => o.mealName === m.name));
                        if(hasOrdersInCat) {
                            sheetHtml += `<div style="background:#f8fafc; padding:0.4rem; font-weight:bold; margin: 1rem 0 0.5rem 0; font-size:0.9rem; text-transform:uppercase; border-left:3px solid var(--primary);">${typeLabel}s</div>`;
                            mealsOfThisType.forEach(meal => {
                                const mealOrders = currentOrders.filter(o => o.mealName === meal.name);
                                if(mealOrders.length > 0) {
                                    let compHtml = meal.composition ? `<br><span style="font-size:0.8rem; font-style:italic; color:#475569;">(${meal.composition})</span>` : '';
                                    sheetHtml += `<div class="print-meal-row"><div class="print-meal-name" style="font-weight:600;">🍽️ ${meal.name} ${compHtml}<span class="print-meal-qty" style="float:right;">x ${mealOrders.length}</span></div>`;
                                    const allergies = mealOrders.filter(o => o.remarks !== '').map(o => `<strong>${escapeHtml(o.name)}</strong> : ${escapeHtml(o.remarks)}`);
                                    if(allergies.length > 0) {
                                        sheetHtml += `<ul class="print-allergies-list">`;
                                        allergies.forEach(item => { sheetHtml += `<li>⚠️ ${item}</li>`; });
                                        sheetHtml += `</ul>`;
                                    }
                                    sheetHtml += `</div>`;
                                }
                            });
                        }
                    });
                }
                sheetHtml += `</div>`;
            });
            sheetHtml += `<button type="button" class="print-inline-btn" onclick="triggerSectionPrint('organizer')">🖨️ Imprimer uniquement ce Food Truck</button></div>`;
            printableArea.innerHTML += sheetHtml;
        });
    }

    function triggerSectionPrint(targetName) {
        document.body.className = `mode-admin print-active-${targetName}`;
        window.print();
        setTimeout(() => { document.body.className = "mode-admin"; }, 600);
    }

    function exportCalculatedCSV() {
        if(appVotes.length === 0) { alert("Aucune donnée."); return; }
        let csvContent = "\uFEFF"; csvContent += "=== RESUME QUANTITATIF ===\nJour;Service;Camion;Plat;Quantite\n";
        const summary = {};
        appVotes.forEach(v => { const key = `${v.day};${v.time};${v.truckName};${v.mealName}`; summary[key] = (summary[key] || 0) + 1; });
        for (let k in summary) { csvContent += `${k};${summary[k]}\n`; }
        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob); const link = document.createElement("a");
        link.setAttribute("href", url); link.setAttribute("download", "recap_commandes.csv");
        document.body.appendChild(link); link.click(); document.body.removeChild(link);
    }

    function verifierMotDePasseAdmin() {
        const input = prompt("🔐 Action critique. Saisissez le mot de passe administrateur pour confirmer :");
        return input === ADMIN_PASSWORD;
    }

    function clearAllReservations() {
        if (!verifierMotDePasseAdmin()) { alert("❌ Mot de passe erroné ou action annulée."); return; }
        if (confirm("🚨 Êtes-vous sûr de vouloir supprimer L'INTÉGRALITÉ des réservations de repas effectuées par les utilisateurs ?")) {
            appVotes = [];
            localStorage.setItem('trucksVotesData', JSON.stringify(appVotes));
            resetDetailsDisplay();
            updateInterface();
            document.getElementById('printableArea').innerHTML = '';
            alert("✅ Toutes les réservations ont été supprimées avec succès.");
        }
    }

    function clearAllMenus() {
        if (!verifierMotDePasseAdmin()) { alert("❌ Mot de passe erroné ou action annulée."); return; }
        if (confirm("🚨 ATTENTION : Vous allez effacer TOUS les Food Trucks et TOUS les menus du catalogue. Les réservations associées deviendront invalides. Confirmer ?")) {
            foodTrucksData = {
                "Vendredi": { "Midi": { "hours": [], "trucks": [] }, "Soir": { "hours": [], "trucks": [] } },
                "Samedi": { "Midi": { "hours": [], "trucks": [] }, "Soir": { "hours": [], "trucks": [] } },
                "Dimanche": { "Midi": { "hours": [], "trucks": [] }, "Soir": { "hours": [], "trucks": [] } },
                "Lundi": { "Midi": { "hours": [], "trucks": [] }, "Soir": { "hours": [], "trucks": [] } }
            };
            localStorage.setItem('config_foodtrucks', JSON.stringify(foodTrucksData));
            cancelEditing();
            resetDetailsDisplay();
            updateInterface();
            alert("✅ Catalogue des menus entièrement vidé.");
        }
    }

    function clearSingleMenu() {
        const mealSelect = document.getElementById('deleteSingleMealSelect');
        const targetMeal = mealSelect.value;
        if (!targetMeal) { alert("Veuillez d'abord choisir un plat dans la liste déroulante."); return; }

        const impactedPeople = Array.from(new Set(
            appVotes.filter(v => v.mealName === targetMeal).map(v => v.name)
        ));

        if (!verifierMotDePasseAdmin()) { alert("❌ Mot de passe erroné ou action annulée."); return; }
        
        for (let day in foodTrucksData) {
            for (let per in foodTrucksData[day]) {
                if (foodTrucksData[day][per].trucks) {
                    foodTrucksData[day][per].trucks.forEach(t => {
                        t.meals = t.meals.filter(m => m.name !== targetMeal);
                    });
                }
            }
        }
        localStorage.setItem('config_foodtrucks', JSON.stringify(foodTrucksData));

        appVotes = appVotes.filter(v => v.mealName !== targetMeal);
        localStorage.setItem('trucksVotesData', JSON.stringify(appVotes));

        cancelEditing();
        resetDetailsDisplay();
        updateInterface();

        const impactContainer = document.getElementById('deleteSingleMealImpactContainer');
        if (impactedPeople.length > 0) {
            impactContainer.innerHTML = `
                <div class="inline-notification warning">
                    <strong>💥 Plat "${targetMeal}" supprimé avec succès !</strong><br>
                    Les réservations des participants suivants ont été nettoyées automatiquement (${impactedPeople.length}) :<br>
                    <span style="font-size:0.85rem; font-weight:bold;">${impactedPeople.join(', ')}</span>
                </div>
            `;
        } else {
            impactContainer.innerHTML = `
                <div class="inline-notification success">
                    ✅ Le plat "${targetMeal}" a été retiré du catalogue (Aucun participant n'était impacté).
                </div>
            `;
        }
        mealSelect.value = "";
    }

    function clearAllParticipants() {
        if (!verifierMotDePasseAdmin()) { alert("❌ Mot de passe erroné ou action annulée."); return; }
        if (confirm("🚨 DANGER : Vous allez supprimer la liste complète des participants autorisés. Confirmer ?")) {
            participantsList = [];
            localStorage.setItem('config_participants', JSON.stringify(participantsList));
            cancelEditing();
            resetDetailsDisplay();
            updateInterface();
            alert("✅ Liste des participants entièrement vidée.");
        }
    }

    function clearSingleParticipant() {
        const userSelect = document.getElementById('deleteSingleUserSelect');
        const targetUser = userSelect.value;
        if (!targetUser) { alert("Veuillez d'abord choisir un profil dans la liste déroulante."); return; }

        if (!verifierMotDePasseAdmin()) { alert("❌ Mot de passe erroné ou action annulée."); return; }

        if (confirm(`Voulez-vous retirer "${targetUser}" de la liste des inscrits ? (Ses réservations de repas associées seront également nettoyées).`)) {
            participantsList = participantsList.filter(p => p.name !== targetUser);
            localStorage.setItem('config_participants', JSON.stringify(participantsList));

            appVotes = appVotes.filter(v => v.name.toLowerCase() !== targetUser.toLowerCase());
            localStorage.setItem('trucksVotesData', JSON.stringify(appVotes));

            cancelEditing();
            resetDetailsDisplay();
            updateInterface();
            alert(`✅ L'utilisateur "${targetUser}" et ses choix de repas ont été supprimés.`);
        }
    }

    function escapeHtml(text) {
        return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    initParticipantsSelect();
	
	function addPersonManually() {
    const nameInput = document.getElementById('newPersonName');
    const roleInput = document.getElementById('newPersonRole');
    const name = nameInput.value.trim();
    const role = roleInput.value;

    if (!name) {
        alert("⚠️ Veuillez saisir un nom et un prénom.");
        return;
    }

    // Vérifier si le nom existe déjà
    if (participantsList.some(p => p.name.toLowerCase() === name.toLowerCase())) {
        alert("⚠️ Ce nom est déjà dans la liste.");
        return;
    }

    // Ajouter à la liste
    participantsList.push({ name: name, role: role });
    participantsList.sort((a, b) => a.name.localeCompare(b.name));
    
    // Sauvegarder
    localStorage.setItem('config_participants', JSON.stringify(participantsList));

    // Mettre à jour l'interface
    initParticipantsSelect();
    syncDetPersonDropdown();
    updateInterface(); // Force la mise à jour des vues administratives

    // Réinitialiser le champ
    nameInput.value = '';
    alert(`✅ ${name} a été ajouté(e) avec succès !`);
}

function exportParticipantsCSV() {
    let csvContent = "\uFEFFNom;Groupe\n"; // \uFEFF pour forcer l'encodage UTF-8 (accents)
    
    participantsList.forEach(p => {
        csvContent += `${p.name};${p.role}\n`;
    });

    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    link.setAttribute("download", "liste_participants.csv");
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}
	
