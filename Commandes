            lines.forEach((line, index) => {
                if (index === 0 || line.trim() === "") return;
                let separator = line.includes(';') ? ';' : ',';
                let columns = line.split(separator).map(c => c.replace(/"/g, '').trim());
                
                if (columns[0] && columns[0] !== "") {
                    let name = columns[0];
                    let roleRaw = columns[1] ? columns[1].toLowerCase() : "team";
                    let roleClean = roleRaw.includes("staff") ? "Staff" : "Team";
                    
                    if (mode === 'append') {
                        let exists = temporaryList.some(p => p.name.toLowerCase() === name.toLowerCase() && p.role === roleClean);
                        if (!exists) temporaryList.push({ name: name, role: roleClean });
                    } else {
                        temporaryList.push({ name: name, role: roleClean });
                    }
                }
            });
            
            if(temporaryList.length > 0) {
