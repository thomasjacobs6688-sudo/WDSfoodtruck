    function updateInterface() {
        if(currentRole !== "admin") return;
        
        dashboardContainer.innerHTML = '';
        const structureCalcul = {};
        for (let j in foodTrucksData) {
            structureCalcul[j] = {};
            const allHoursOfDay = foodTrucksData[j]["Midi"].hours.concat(foodTrucksData[j]["Soir"].hours);
            allHoursOfDay.forEach(h => { structureCalcul[j][h] = {}; });
        }
        appVotes.forEach(v => {
            const conf = helperObtenirPrixEtConfigPlat(v.day, v.period, v.mealName);
            const displayMealString = `[${conf.type}] ${v.truckName} - ${v.mealName}`;
            if(structureCalcul[v.day] && structureCalcul[v.day][v.time]) {
                if (!structureCalcul[v.day][v.time][displayMealString]) {
                    structureCalcul[v.day][v.time][displayMealString] = { quantite: 0, prixU: conf.prix };
                }
                structureCalcul[v.day][v.time][displayMealString].quantite += 1;
            }
        });
        const orderedDays = ["Vendredi", "Samedi", "Dimanche", "Lundi"];
        orderedDays.forEach(day => {
            if (!structureCalcul[day]) return;
            let dayHtml = `<div class="day-summary-box"><div class="day-title">📅 ${day}</div>`;
            let emptyDay = true;
            const sortedHours = Object.keys(structureCalcul[day]).sort((a, b) => parseInt(a) - parseInt(b));
            sortedHours.forEach(time => {
                const mealsOrdered = structureCalcul[day][time];
                if (Object.keys(mealsOrdered).length > 0) {
                    emptyDay = false;
                    dayHtml += `<div class="service-block"><div class="service-title">⏱️ Service de ${time}</div><ul class="meal-count-list">`;
                    let totalService = 0; let budgetService = 0;
                    for (let m in mealsOrdered) {
                        const qte = mealsOrdered[m].quantite; const pU = mealsOrdered[m].prixU; const sousTotal = qte * pU;
                        dayHtml += `<li><span>${m} (x${qte})</span><strong>${sousTotal.toFixed(2)} €</strong></li>`;
                        totalService += qte; budgetService += sousTotal;
                    }
                    dayHtml += `<li style="font-weight:bold; color:var(--primary); border-top:1px dashed #cbd5e1; margin-top:5px; padding-top:5px;"><span>Total (${totalService} articles) :</span><span style="color:#16a34a;">${budgetService.toFixed(2)} €</span></li></ul></div>`;
                }
            });
            if(emptyDay) dayHtml += `<p style="font-size:0.85rem; color:#94a3b8; font-style:italic;">Aucune commande.</p>`;
            dayHtml += `</div>`; dashboardContainer.innerHTML += dayHtml;
