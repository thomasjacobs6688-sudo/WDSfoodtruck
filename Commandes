            return;
        }

        const { originalDay, originalPeriod, originalTruck, originalMealName } = currentEditingMeal;

        if(foodTrucksData[originalDay] && foodTrucksData[originalDay][originalPeriod]) {
            let tIdx = foodTrucksData[originalDay][originalPeriod].trucks.findIndex(t => t.name === originalTruck);
            if(tIdx !== -1) {
                foodTrucksData[originalDay][originalPeriod].trucks[tIdx].meals = foodTrucksData[originalDay][originalPeriod].trucks[tIdx].meals.filter(m => m.name !== originalMealName);
