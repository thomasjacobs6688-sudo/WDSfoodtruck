    function exportMenusCSV() {
        let csvContent = "\uFEFF";
        csvContent += "Jour;Periode;Heures;FoodTruck;Type;Plat;Composition;Prix\n";
        
        for (let day in foodTrucksData) {
            for (let per in foodTrucksData[day]) {
                const block = foodTrucksData[day][per];
                const hoursPipe = block.hours.join('|');
                if(block.trucks) {
                    block.trucks.forEach(t => {
                        t.meals.forEach(m => {
                            const cleanComp = (m.composition || "").replace(/"/g, '""');
                            csvContent += `"${day}";"${per}";"${hoursPipe}";"${t.name}";"${m.type || 'Plat'}";"${m.name}";"${cleanComp}";${m.prix}\n`;
                        });
                    });
                }
            }
        }
        
        const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.setAttribute("href", url);
        link.setAttribute("download", "planning_foodtrucks_export.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }

