    document.getElementById('csvMenusFile').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;
        const mode = document.querySelector('input[name="modeMenus"]:checked').value;
        const reader = new FileReader();
        reader.onload = function(evt) {
            const text = evt.target.result;
            const lines = text.split(/\r?\n/);
            
            let tempStructure;
            if (mode === 'append') {
                tempStructure = JSON.parse(JSON.stringify(foodTrucksData));
            } else {
                tempStructure = {
                    "Vendredi": {"Midi": {"hours": [], "trucks": []}, "Soir": {"hours": [], "trucks": []}},
                    "Samedi": {"Midi": {"hours": [], "trucks": []}, "Soir": {"hours": [], "trucks": []}},
                    "Dimanche": {"Midi": {"hours": [], "trucks": []}, "Soir": {"hours": [], "trucks": []}},
                    "Lundi": {"Midi": {"hours": [], "trucks": []}, "Soir": {"hours": [], "trucks": []}}
                };
            }

            lines.forEach((line, index) => {
                if (index === 0 || line.trim() === "") return;
                let separator = line.includes(';') ? ';' : ',';
                let matches = []; let match;
                let regex = new RegExp(`([^"${separator}]+)|"([^"]*)"|(?<=${separator})`, 'g');
                while ((match = regex.exec(line)) !== null) { matches.push(match[1] || match[2] || ""); }
                let columns = matches.map(c => c.trim());
                
                if(columns.length >= 6) {
                    let day = columns[0]; let period = columns[1]; let hoursArray = columns[2].split('|');
                    let truckName = columns[3]; let mealType = columns[4] ? columns[4] : "Plat";
                    let mealName = columns[5]; let composition = columns[6] ? columns[6] : "";
                    let price = columns[7] ? parseFloat(columns[7].replace(',', '.')) : 0.0;
                    
                    if(tempStructure[day] && tempStructure[day][period]) {
                        if (mode === 'append') {
                            hoursArray.forEach(h => {
                                if(!tempStructure[day][period].hours.includes(h)) tempStructure[day][period].hours.push(h);
                            });
                        } else {
                            tempStructure[day][period].hours = hoursArray;
                        }

                        let truck = tempStructure[day][period].trucks.find(t => t.name === truckName);
                        if(!truck) { 
                            truck = { name: truckName, meals: [] }; 
                            tempStructure[day][period].trucks.push(truck); 
                        }
                        
                        let mealExists = truck.meals.some(m => m.name === mealName);
                        if (!mealExists) {
                            truck.meals.push({ name: mealName, prix: price, type: mealType, composition: composition });
                        }
                    }
                }
            });
            
            foodTrucksData = tempStructure;
            localStorage.setItem('config_foodtrucks', JSON.stringify(foodTrucksData));
            cancelEditing();
            updateInterface();
            alert(mode === 'append' ? "➕ Planning mis à jour et complété !" : "✅ Tout le planning a été écrasé et remplacé !");
            e.target.value = '';
        };
        reader.readAsText(file, "UTF-8");
    });

