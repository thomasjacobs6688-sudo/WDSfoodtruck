        if (!foodTrucksData[newDay]) foodTrucksData[newDay] = {};
        if (!foodTrucksData[newDay][newPeriod]) {
            foodTrucksData[newDay][newPeriod] = { hours: [], trucks: [] };
        }
        
        foodTrucksData[newDay][newPeriod].hours = newHours;
        
        let targetTruck = foodTrucksData[newDay][newPeriod].trucks.find(t => t.name === newTruck);
        if(!targetTruck) {
            targetTruck = { name: newTruck, meals: [] };
            foodTrucksData[newDay][newPeriod].trucks.push(targetTruck);
        }
        targetTruck.meals.push({ name: newPlat, prix: newPrix, type: newType, composition: newComp });

        let impactedUsers = [];
        appVotes.forEach(v => {
            if(v.day === originalDay && v.period === originalPeriod && v.truckName === originalTruck && v.mealName === originalMealName) {
                v.day = newDay;
                v.period = newPeriod;
                v.truckName = newTruck;
