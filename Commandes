        document.getElementById('editMenuPlat').value = "";
        document.getElementById('editMenuPrix').value = "";
        document.getElementById('editMenuComp').value = "";
        document.getElementById('editMenuHours').value = "";
        document.getElementById('btnUpdateManual').style.display = "none";
        document.getElementById('btnCreateManual').style.display = "block";

        cancelEditing();
        updateInterface();

        const logBox = document.getElementById('editMenuStatusLog');
        if (impactedUsers.length > 0) {
            const uniqueImpacted = Array.from(new Set(impactedUsers));
            logBox.innerHTML = `
                <div class="inline-notification warning" style="margin-top:1.5rem;">
                    <strong>✅ Plat modifié avec succès !</strong><br>
