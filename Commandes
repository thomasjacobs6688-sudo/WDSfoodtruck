<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>West Duck swing - Réservation repas</title>
    <style>
        :root {
            --primary: #0f172a;
            --accent: #f59e0b;
            --bg: #f1f5f9;
            --card-bg: #ffffff;
            --text: #334155;
            --border: #cbd5e1;
            --truck-a: #eff6ff;
            --truck-b: #fef2f2;
            --warning-bg: #fffbeb;
            --warning-border: #fef3c7;
            --warning-text: #b45309;
            --danger-bg: #fef2f2;
            --danger-text: #991b1b;
            --success-bg: #f0fdf4;
            --success-border: #bbf7d0;
            --success-text: #166534;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            padding: 2rem 1rem;
            line-height: 1.5;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-text h1 { margin-bottom: 0.5rem; }

        .admin-toggle-btn {
            width: auto;
            background-color: #475569;
            padding: 0.6rem 1.2rem;
            font-size: 0.95rem;
        }
        .admin-toggle-btn.active {
            background-color: #b91c1c;
        }

        .admin-only, .user-only { display: none; }
        body.mode-user .user-only { display: block; }
        body.mode-admin .admin-only { display: block; }

        .card {
            background: var(--card-bg);
            border-radius: 12px;
            padding: 2rem;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
            height: fit-content;
            margin-bottom: 2rem;
        }

        .card.edit-highlight {
            border: 2px dashed var(--accent);
            background: #fffbeb;
        }

        .card-header-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--bg);
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
        }
        .card-header-actions h2 { border-bottom: none; margin-bottom: 0; }

        h2 {
            margin-bottom: 1.5rem;
            font-size: 1.3rem;
            border-bottom: 2px solid var(--bg);
            padding-bottom: 0.5rem;
            color: var(--primary);
        }

        .form-group { margin-bottom: 1.5rem; }

        label.main-label {
            display: block;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: #1e293b;
        }

        input[type="text"], input[type="number"], select, textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 1rem;
            background: white;
            transition: border-color 0.2s;
        }

        .inline-radios { display: flex; gap: 1rem; flex-wrap: wrap; }

        .radio-tile {
            flex: 1;
            min-width: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.75rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
        }

        .menu-container { display: flex; flex-direction: column; gap: 1rem; }

        .truck-section { padding: 1rem; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 1rem;}
        .truck-section.truck-0 { background-color: var(--truck-a); border-color: #bfdbfe; }
        .truck-section.truck-1 { background-color: var(--truck-b); border-color: #fecaca; }

        .truck-name { font-weight: bold; font-size: 1.1rem; margin-bottom: 0.75rem; border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 0.25rem;}
        
        .menu-type-title {
            font-size: 0.9rem;
            font-weight: bold;
            text-transform: uppercase;
            color: #475569;
            margin: 0.75rem 0 0.25rem 0;
            letter-spacing: 0.05em;
        }

        .menu-item-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            background: white;
            padding: 0.6rem;
            margin-bottom: 0.4rem;
            border-radius: 6px;
            cursor: pointer;
            border: 1px solid #e2e8f0;
        }
        
        .item-text-block { display: flex; flex-direction: column; }
        .item-composition { font-size: 0.8rem; font-style: italic; color: #64748b; margin-top: 0.15rem; }
        .menu-item-price { font-weight: bold; color: #16a34a; font-size: 0.95rem; }

        button {
            width: 100%;
            padding: 0.85rem;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
        }

        button.secondary { background-color: transparent; color: var(--primary); border: 1px solid var(--primary); margin-top: 1rem;}
        button.print-section-btn { width: auto; background-color: #1e293b; font-size: 0.85rem; padding: 6px 12px; }
        button.danger { background-color: transparent; color: #dc2626; border: 1px solid #dc2626; margin-top: 2rem; }
        button.danger-filled { background-color: #dc2626; color: white; border: none; font-size: 0.9rem; padding: 0.6rem 1rem; }
        
        .btn-edit {
            background-color: var(--accent);
            color: white;
            border: none;
            padding: 4px 8px;
            font-size: 0.75rem;
            font-weight: bold;
            border-radius: 4px;
            cursor: pointer;
            width: auto;
        }

        .user-history-box {
            background-color: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 8px;
            padding: 1rem;
            margin-top: 0.75rem;
        }
        .user-history-title { font-size: 0.9rem; font-weight: bold; color: #475569; margin-bottom: 0.5rem; }
        .user-history-list { list-style: none; font-size: 0.85rem; }
        .user-history-item {
            background: white;
            border: 1px solid #e2e8f0;
            padding: 0.5rem;
            border-radius: 6px;
            margin-bottom: 0.4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .day-summary-box { background: #f8fafc; border: 1px solid var(--border); border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem; }
        .day-title { font-weight: 800; background: #e2e8f0; padding: 0.3rem 0.6rem; border-radius: 4px; margin-bottom: 0.75rem; }
        .service-block { margin-left: 0.5rem; margin-bottom: 0.75rem; }
        .service-title { font-weight: 700; color: #475569; font-size: 0.95rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.2rem; margin-bottom: 0.3rem; }
        .meal-count-list { list-style: none; font-size: 0.9rem; padding-left: 0.5rem; }
        .meal-count-list li { display: flex; justify-content: space-between; padding: 0.15rem 0; }
        
        .print-only-title { display: none; font-size: 1.4rem; font-weight: bold; margin-bottom: 1.5rem; border-bottom: 2px solid #000; padding-bottom: 0.5rem; text-align: center; }

        .org-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
        .det-controls { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1rem; align-items: flex-end; }
        
        .print-sheet { background: white; border: 2px dashed #94a3b8; padding: 2rem; border-radius: 8px; margin-top: 1.5rem; }
        .print-header { text-align: center; border-bottom: 3px double var(--primary); padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .print-truck-title { font-size: 1.6rem; font-weight: bold; color: #000; }
        .print-day-sub { font-size: 1.1rem; color: #475569; margin-top: 0.25rem; font-weight: 600; }
        .print-service-section { margin-bottom: 2rem; background: #fff; padding: 1rem; border: 1px solid #cbd5e1; border-radius: 6px;}
        .print-service-title { display: flex; justify-content: space-between; font-weight: bold; font-size: 1.05rem; background: #334155; color: white; padding: 0.4rem 0.6rem; border-radius: 4px; margin-bottom: 0.5rem; }
        .print-meal-row { margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px dashed #e2e8f0; }
        .print-meal-qty { font-size: 1.2rem; font-weight: bold; background: #e2e8f0; padding: 2px 10px; border-radius: 4px; }
        .print-allergies-list { margin-top: 0.5rem; padding-left: 1.2rem; font-size: 0.9rem; color: #b45309; list-style: inside dashed; }

        .details-split-container {
            display: flex;
            gap: 2rem;
            margin-top: 1rem;
            align-items: flex-start;
        }
        
        .details-left-side {
            flex: 1;
            min-width: 0;
        }
        
        .details-right-side {
            width: 380px;
            flex-shrink: 0;
        }

        @media (max-width: 900px) {
            .details-split-container {
                flex-direction: column;
            }
            .details-right-side {
                width: 100%;
            }
        }

        .details-table-wrapper { overflow-x: auto; }
        .details-table { width: 100%; border-collapse: collapse; background: white; font-size: 0.9rem; }
        .details-table th, .details-table td { padding: 0.75rem; border: 1px solid var(--border); text-align: left; }
        .details-table th { background: #f8fafc; font-weight: 700; color: var(--primary); }
        .details-table tr:nth-child(even) { background-color: #f8fafc; }
        .text-right { text-align: right; }
        .badge-total { font-weight: bold; color: #16a34a; }
        .badge-role { display: inline-block; padding: 2px 6px; font-size: 0.75rem; font-weight: 600; border-radius: 4px; margin-left: 0.5rem; }
        .badge-team { background-color: #e0f2fe; color: #0369a1; }
        .badge-staff { background-color: #f3e8ff; color: #6b21a8; }

        .absents-box { background: var(--danger-bg); border: 1px dashed #fca5a5; padding: 1rem; border-radius: 8px; margin-bottom: 0; height: auto; }
        .absents-title { font-weight: bold; color: var(--danger-text); margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center; }
        .absents-list { font-size: 0.9rem; color: #7f1d1d; padding-left: 1.2rem; margin: 0; }

        .global-absents-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.75rem; }
        .global-absents-column { background: #f8fafc; border: 1px solid var(--border); border-radius: 6px; padding: 1rem; }
        .global-absents-column h4 { font-size: 0.95rem; margin-bottom: 0.5rem; padding-bottom: 0.25rem; border-bottom: 1px solid var(--border); }
        .global-absents-column.team h4 { color: #0369a1; }
        .global-absents-column.staff h4 { color: #6b21a8; }
        .global-absents-ul { font-size: 0.85rem; list-style-type: none; padding-left: 0; max-height: 150px; overflow-y: auto; }
        .global-absents-ul li { padding: 0.2rem 0; border-bottom: 1px dashed #e2e8f0; }
        .global-absents-ul li:last-child { border-bottom: none; }

        #detailsResultZone { display: none; margin-top: 1.5rem; }

        .csv-box { background: #f8fafc; border: 1px solid var(--border); padding: 1rem; border-radius: 8px; margin-bottom: 1rem; }
        .csv-box input[type="file"] { margin-top: 0.5rem; font-size: 0.9rem; }
        .csv-mode-selector { display: flex; gap: 1rem; margin-top: 0.5rem; font-size: 0.85rem; background: #fff; padding: 0.4rem; border-radius: 4px; border: 1px solid #e2e8f0;}
        .csv-mode-selector label { display: flex; align-items: center; gap: 0.25rem; cursor: pointer; font-weight: 500;}

        button.print-inline-btn { width: auto; background-color: #16a34a; font-size: 0.85rem; padding: 6px 12px; margin-top: 1rem;}

        .security-sub-section { background: white; border: 1px solid #fecaca; border-radius: 8px; padding: 1.2rem; margin-bottom: 1rem; }
        .security-action-flex { display: flex; gap: 1rem; align-items: flex-end; margin-top: 0.5rem; flex-wrap: wrap; }
        .security-action-flex div { flex: 1; min-width: 250px; }

        .inline-notification {
            margin-top: 0.75rem;
            padding: 0.75rem;
            border-radius: 6px;
            font-size: 0.9rem;
            border: 1px solid var(--border);
        }
        .inline-notification.warning { background: var(--warning-bg); border-color: var(--warning-border); color: var(--warning-text); }
        .inline-notification.success { background: var(--success-bg); border-color: var(--success-border); color: var(--success-text); }

        @media print {
            header, button, input, select, textarea, .csv-box, .org-controls, .det-controls, .user-only, .global-absents-search-box { 
                display: none !important; 
            }
            
            body { 
                background: white !important; 
                padding: 0 !important; 
                color: #000 !important; 
            }
            .container { 
                max-width: 100% !important; 
                width: 100% !important; 
                margin: 0 !important; 
                padding: 0 !important; 
            }

            body.print-active-dashboard .card:not(.dashboard-print-zone) { display: none !important; }
            body.print-active-dashboard .dashboard-print-zone { display: block !important; box-shadow: none !important; padding: 0 !important; }
            body.print-active-dashboard .dashboard-print-zone .card-header-actions { display: none !important; }
            body.print-active-dashboard .dashboard-print-zone .print-only-title { display: block !important; }

            body.print-active-organizer .card { display: none !important; }
            body.print-active-organizer .organizer-print-zone { display: block !important; position: absolute; top: 0; left: 0; width: 100% !important; }
            body.print-active-organizer .print-sheet { border: none !important; padding: 0 !important; margin: 0 0 30px 0 !important; page-break-after: always; }
            body.print-active-organizer .print-service-section { border: 1px solid #000 !important; page-break-inside: avoid; }

            body.print-active-details .card:not(.details-print-zone) { display: none !important; }
            body.print-active-details .details-print-zone { display: block !important; box-shadow: none !important; padding: 0 !important; }
            body.print-active-details .details-print-zone .card-header-actions { display: none !important; }
            body.print-active-details .details-print-zone .print-only-title { display: block !important; }
            #detailsResultZone { display: block !important; } 
            .details-split-container { flex-direction: column !important; gap: 1.5rem !important; }
            .details-right-side { width: 100% !important; }
        }
    </style>
</head>
<body class="mode-user">

<div class="container">
    <header>
        <div class="header-text">
            <h1>West Duck swing - Réservation repas</h1>
            <p class="user-only" style="color: #64748b;">Sélectionnez votre groupe puis votre nom pour soumettre ou réajuster vos choix de repas.</p>
            <p class="admin-only" style="color: #b45309; font-weight: bold;">🔴 Mode Administrateur Connecté — Contrôle Global</p>
        </div>
        <button type="button" id="adminToggleBtn" class="admin-toggle-btn" onclick="toggleAdminMode()">🔐 Mode Admin</button>
    </header>

    <div class="user-only">
        <div id="formCard" class="card">
            <h2 id="formTitle">Formulaire d'inscription</h2>
            <form id="mainForm">
                <div class="form-group">
                    <label class="main-label">Vous êtes ?</label>
                    <div class="inline-radios" style="max-width: 300px;">
                        <label class="radio-tile">
                            <input type="radio" name="userGroupFilter" value="Team" checked onchange="initParticipantsSelect()"> 🏃 Team
                        </label>
                        <label class="radio-tile">
                            <input type="radio" name="userGroupFilter" value="Staff" onchange="initParticipantsSelect()"> 🛠️ Staff
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="main-label" for="usernameSelect">Nom & Prénom</label>
                    <select id="usernameSelect" required></select>
                    <div id="userHistoryContainer" style="display: none;"></div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label class="main-label">Sélectionnez le Jour</label>
                        <select id="daySelect">
                            <option value="Indifférent" disabled selected>-- Choisir --</option>
                            <option value="Par jour" disabled>--- Par Jour ---</option>
                            <option value="Vendredi">Vendredi</option>
                            <option value="Samedi">Samedi</option>
                            <option value="Dimanche">Dimanche</option>
                            <option value="Lundi">Lundi</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="main-label">Moment de la journée</label>
                        <div class="inline-radios">
                            <label class="radio-tile">
                                <input type="radio" name="period" value="Midi" checked> ☀️ Midi
                            </label>
                            <label class="radio-tile">
                                <input type="radio" name="period" value="Soir"> 🌙 Soir
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="main-label">Heure du service souhaitée</label>
                    <div class="inline-radios" id="timeOptionsContainer"></div>
                </div>

                <div class="form-group">
                    <label class="main-label" style="color: var(--accent);">👉 Cochez vos repas ci-dessous :</label>
                    <div class="menu-container" id="trucksMenuContainer"></div>
                </div>

                <div class="form-group">
                    <label class="main-label" for="remarks">Remarques / Allergies</label>
                    <textarea id="remarks" placeholder="Ex: Allergie aux arachides, végétarien... (Optionnel)"></textarea>
                </div>

                <button type="submit" id="submitBtn">Enregistrer les choix sélectionnés</button>
                <button type="button" id="cancelEditBtn" class="secondary" style="display: none; margin-top: 0.5rem;" onclick="cancelEditing()">Annuler la modification</button>
            </form>
        </div>
    </div>

    <!-- ZONE ADMINISTRATEUR -->
    <div class="admin-only">
        <div class="card" style="border: 2px solid #3b82f6;">
            <h2>📥 Importation de Données (Participants & Menus)</h2>
            <p style="color: #64748b; margin-bottom: 1.5rem; font-size:0.9rem;">Importez vos fichiers pour initialiser ou compléter les listes.</p>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="csv-box">
                    <label class="main-label">1. Liste des Participants (.csv)</label>
                    <span style="font-size:0.8rem; color:#64748b;">Format : <i>Nom Prenom;Groupe</i> (Team ou Staff)</span>
                    <input type="file" id="csvParticipantsFile" accept=".csv">
                    <div class="csv-mode-selector">
                        <label><input type="radio" name="modeParticipants" value="replace" checked> 💥 Écraser l'ancienne liste</label>
                        <label><input type="radio" name="modeParticipants" value="append"> ➕ Ajouter à la suite</label>
                    </div>
                </div>
                
                <div class="csv-box">
                    <label class="main-label">2. Planning des Food Trucks (.csv)</label>
                    <span style="font-size:0.8rem; color:#64748b;">Format : <i>Jour,Periode,Heures,FoodTruck,Type,Plat,Composition,Prix</i></span>
                    <input type="file" id="csvMenusFile" accept=".csv">
                    <div class="csv-mode-selector">
                        <label><input type="radio" name="modeMenus" value="replace" checked> 💥 Écraser tout le planning</label>
                        <label><input type="radio" name="modeMenus" value="append"> ➕ Ajouter/Compléter les menus</label>
                    </div>
                </div>
            </div>
        </div>
		
		
		<!-- === NOUVEAU BLOC : AJOUTER DES PERSONNES === -->
		
        <div class="card" style="border: 2px solid #3b82f6;">
            <h2>👤 Ajouter des personnes</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 1rem; align-items: end;">
                <div class="form-group" style="margin-bottom:0;">
                    <label class="main-label">Nom & Prénom</label>
                    <input type="text" id="newPersonName" placeholder="Ex: Jean Dupont">
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="main-label">Groupe</label>
                    <select id="newPersonRole">
                        <option value="Team">Team</option>
                        <option value="Staff">Staff</option>
                    </select>
                </div>
                <button type="button" onclick="addPersonManually()" style="width: auto;">➕ Ajouter nom</button>
            </div>
            <button type="button" class="secondary" onclick="exportParticipantsCSV()">📥 Télécharger liste complète (CSV)</button>
        </div>
		
		

        <!-- BLOC GESTION MANUELLE DES PLATS -->
        <div class="card" style="border: 2px solid var(--accent); background: #fefcfb;">
            <h2>📝 Ajout & Modification Manuelle des Plats</h2>
            <p style="color: #64748b; margin-bottom: 1.5rem; font-size:0.9rem;">Sélectionnez un plat existant pour le modifier/ajuster, OU laissez le sélecteur vide pour concevoir et injecter un tout nouveau plat oublié.</p>
            
            <div class="form-group">
                <label class="main-label" for="editMenuSelector">Choisir un plat à modifier (Laisser vide pour une NOUVELLE CRÉATION 🆕)</label>
                <select id="editMenuSelector" onchange="populateMenuEditFields()">
                    <option value="" selected>✨ -- CRÉER UN NOUVEAU PLAT OUBLIÉ --</option>
                </select>
            </div>

            <div id="editMenuImpactedUsers"></div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1.2rem;">
                <div class="form-group">
                    <label class="main-label">Jour</label>
                    <select id="editMenuDay">
                        <option value="Vendredi">Vendredi</option>
                        <option value="Samedi">Samedi</option>
                        <option value="Dimanche">Dimanche</option>
                        <option value="Lundi">Lundi</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="main-label">Période</label>
                    <select id="editMenuPeriod">
                        <option value="Midi">☀️ Midi</option>
                        <option value="Soir">🌙 Soir</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="main-label">Heures du bloc (Séparer par |)</label>
                    <input type="text" id="editMenuHours" placeholder="Ex: 11h30|12h30">
                </div>
                <div class="form-group">
                    <label class="main-label">Nom du Food Truck</label>
                    <input type="text" id="editMenuTruck" placeholder="Ex: Burger Station">
                </div>
                <div class="form-group">
                    <label class="main-label">Type d'article</label>
                    <select id="editMenuType">
                        <option value="Entrée">Entrée</option>
                        <option value="Plat" selected>Plat</option>
                        <option value="Dessert">Dessert</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="main-label">Nom du Plat / Article</label>
                    <input type="text" id="editMenuPlat" placeholder="Ex: Menu Burger Végé">
                </div>
                <div class="form-group">
