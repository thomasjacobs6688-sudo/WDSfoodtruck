<script>
    const ADMIN_PASSWORD = "admin123";
    const TYPE_ORDER_MAPPING = { "Entrée": 1, "Plat": 2, "Dessert": 3 };

    let participantsList = JSON.parse(localStorage.getItem('config_participants')) || [
        { name: "Alice Martin", role: "Team" },
        { name: "Lucas Bernard", role: "Staff" },
        { name: "Chloé Petit", role: "Team" }
    ];

    let foodTrucksData = JSON.parse(localStorage.getItem('config_foodtrucks')) || {
        "Vendredi": {
            "Midi": { "hours": ["11h30", "12h30"], "trucks": [{ name: "Burger Station", meals: [{ name: "Menu Burger Classique", prix: 13.50, type: "Plat", composition: "Boeuf steak haché, frites maison, cheddar fondu" }, { name: "Cookie Chocolat", prix: 3.50, type: "Dessert", composition: "Pépites chocolat au lait et morceaux de noisettes" }] }] },
            "Soir": { "hours": ["19h30", "21h30"], "trucks": [{ name: "Pizza Traditional", meals: [{ name: "Pizza Margherita", prix: 9.50, type: "Plat", composition: "Sauce tomate, mozzarella, basilic frais, huile d'olive" }] }] }
        },
        "Samedi": { "Midi": { "hours": ["12h00"], "trucks": [] }, "Soir": { "hours": ["20h00"], "trucks": [] } },
        "Dimanche": { "Midi": { "hours": ["12h15"], "trucks": [] }, "Soir": { "hours": ["20h30"], "trucks": [] } },
        "Lundi": { "Midi": { "hours": ["11h45"], "trucks": [] }, "Soir": { "hours": ["19h00"], "trucks": [] } }
    };

    let appVotes = JSON.parse(localStorage.getItem('trucksVotesData')) || [];
    let isEditingMode = false;
    let currentRole = "user";
    let currentEditingMeal = null;

    const usernameSelect = document.getElementById('usernameSelect');
    const userHistoryContainer = document.getElementById('userHistoryContainer');
    const daySelect = document.getElementById('daySelect');
    const periodRadios = document.getElementsByName('period');
    const timeOptionsContainer = document.getElementById('timeOptionsContainer');
    const trucksMenuContainer = document.getElementById('trucksMenuContainer');
    const dashboardContainer = document.getElementById('dashboardContainer');
    const mainForm = document.getElementById('mainForm');
    const adminToggleBtn = document.getElementById('adminToggleBtn');

    function helperObtenirPrixEtConfigPlat(jour, moment, nomPlat) {
        let result = { prix: 0, type: "Plat", composition: "" };
        if (!foodTrucksData[jour] || !foodTrucksData[jour][moment]) return result;
        
        foodTrucksData[jour][moment].trucks.forEach(t => {
            const mMatch = t.meals.find(m => m.name === nomPlat);
            if (mMatch) {
                result = { 
                    prix: mMatch.prix, 
                    type: mMatch.type || "Plat", 
                    composition: mMatch.composition || ""
                };
            }
        });
        return result;
    }

    function toggleAdminMode() {
        if (currentRole === "user") {
            const pwd = prompt("Saisissez le mot de passe administrateur :");
            if (pwd === ADMIN_PASSWORD) {
                currentRole = "admin";
                document.body.className = "mode-admin";
                adminToggleBtn.innerText = "🔓 Quitter Admin";
                adminToggleBtn.classList.add('active');
                syncDetPersonDropdown();
                resetDetailsDisplay();
                updateInterface();
            } else if (pwd !== null) {
                alert("❌ Mot de passe erroné.");
            }
        } else {
            currentRole = "user";
            document.body.className = "mode-user";
            adminToggleBtn.innerText = "🔐 Mode Admin";
            adminToggleBtn.classList.remove('active');
            cancelEditing();
        }
    }

    function initParticipantsSelect(selectedUserToPreserve = null) {
        const activeGroup = document.querySelector('input[name="userGroupFilter"]:checked').value;
        usernameSelect.innerHTML = `<option value="" disabled ${!selectedUserToPreserve ? 'selected' : ''}>-- Choisir un nom (${activeGroup}) --</option>`;
        
        participantsList.forEach((p) => {
            if(p.name && p.name.trim() !== "" && p.role === activeGroup) {
                const opt = document.createElement('option');
                opt.value = p.name.trim();
                opt.innerText = p.name.trim();
                if (selectedUserToPreserve && p.name.trim().toLowerCase() === selectedUserToPreserve.toLowerCase()) {
                    opt.selected = true;
                }
                usernameSelect.appendChild(opt);
            }
        });
        renderUserHistory();
    }

    function syncDetPersonDropdown() {
        const groupFilter = document.getElementById('detGroupFilter').value;
        const personSelect = document.getElementById('detPersonFilter');
        const currentSelected = personSelect.value;

        personSelect.innerHTML = '<option value="Tous">👥 -- Afficher tout le monde --</option>';

        participantsList.forEach(p => {
            if (p.name && p.name.trim() !== "") {
                if (groupFilter === "Tous" || p.role === groupFilter) {
                    const opt = document.createElement('option');
                    opt.value = p.name.trim();
                    opt.innerText = `${p.name.trim()} (${p.role})`;
                    personSelect.appendChild(opt);
                }
            }
        });

        if (Array.from(personSelect.options).some(o => o.value === currentSelected)) {
            personSelect.value = currentSelected;
        } else {
            personSelect.value = "Tous";
        }
    }

    function resetDetailsDisplay() {
        document.getElementById('detailsResultZone').style.display = "none";
    }

    function processAndShowDetails() {
        renderDetailsAndAbsents();
        document.getElementById('detailsResultZone').style.display = "block";
    }

    function updateGlobalAbsentsLists() {
        if(currentRole !== "admin") return;

        const targetDay = document.getElementById('globalAbsentsDay').value;
        const targetPeriod = document.getElementById('globalAbsentsPeriod').value;
        
        const ulTeam = document.getElementById('listGlobalAbsentTeam');
        const ulStaff = document.getElementById('listGlobalAbsentStaff');
        const spanCountTeam = document.getElementById('countGlobalAbsentTeam');
        const spanCountStaff = document.getElementById('countGlobalAbsentStaff');

        ulTeam.innerHTML = '';
        ulStaff.innerHTML = '';

        let countTeam = 0;
        let countStaff = 0;

        participantsList.forEach(p => {
            const nameClean = p.name.trim();
            if(nameClean === "") return;

            const hasOrdered = appVotes.some(v => v.name.toLowerCase() === nameClean.toLowerCase() && v.day === targetDay && v.period === targetPeriod);

            if(!hasOrdered) {
                const li = document.createElement('li');
                li.innerText = `❌ ${nameClean}`;
                
                if(p.role === "Team") {
                    ulTeam.appendChild(li);
                    countTeam++;
                } else if(p.role === "Staff") {
                    ulStaff.appendChild(li);
                    countStaff++;
                }
            }
        });

        spanCountTeam.innerText = countTeam;
        spanCountStaff.innerText = countStaff;

        if(countTeam === 0) ulTeam.innerHTML = '<li style="color:#166534; font-style:italic;">🎉 Tout le monde a commandé !</li>';
        if(countStaff === 0) ulStaff.innerHTML = '<li style="color:#166534; font-style:italic;">🎉 Tout le monde a commandé !</li>';
    }

    function populateSecurityDropdowns() {
        const mealSelect = document.getElementById('deleteSingleMealSelect');
        const currentVal = mealSelect.value;
        mealSelect.innerHTML = '<option value="" disabled selected>-- Sélectionner un plat --</option>';
        
        for (let day in foodTrucksData) {
            for (let per in foodTrucksData[day]) {
                const block = foodTrucksData[day][per];
                if (block.trucks) {
                    block.trucks.forEach(t => {
                        t.meals.forEach(m => {
                            const op = document.createElement('option');
                            op.value = m.name;
                            const heuresText = block.hours && block.hours.length > 0 ? ` [${block.hours.join('|')}]` : '';
                            op.innerText = `${m.name} (${t.name} - ${day} - ${per}${heuresText})`;
                            mealSelect.appendChild(op);
                        });
                    });
                }
            }
        }
        if(currentVal) {
            mealSelect.value = currentVal;
        } else {
            document.getElementById('deleteSingleMealImpactContainer').innerHTML = '';
        }

        const userSelect = document.getElementById('deleteSingleUserSelect');
        userSelect.innerHTML = '<option value="" disabled selected>-- Sélectionner un profil --</option>';
        participantsList.forEach(p => {
            const op = document.createElement('option');
            op.value = p.name;
            op.innerText = `${p.name} (${p.role})`;
            userSelect.appendChild(op);
        });
    }

    function checkDeleteMealImpact() {
        const mealSelect = document.getElementById('deleteSingleMealSelect');
        const impactContainer = document.getElementById('deleteSingleMealImpactContainer');
        const targetMeal = mealSelect.value;
        
        if (!targetMeal) { impactContainer.innerHTML = ''; return; }

        const impactedPeople = Array.from(new Set(
            appVotes.filter(v => v.mealName === targetMeal).map(v => v.name)
        ));

        if (impactedPeople.length > 0) {
            impactContainer.innerHTML = `
                <div class="inline-notification warning">
                    <strong>⚠️ Attention — Ce plat est actuellement sélectionné par ${impactedPeople.length} utilisateur(s) :</strong><br>
                    <span style="font-size:0.85rem; word-break: break-all;">${impactedPeople.join(', ')}</span><br>
                    <small style="display:block; margin-top:0.25rem; font-style:italic;">Si vous supprimez ce plat, leurs choix associés seront nettoyés immédiatement.</small>
                </div>
            `;
        } else {
            impactContainer.innerHTML = `
                <div class="inline-notification success">
                    🎉 Aucun utilisateur n'a commandé ce plat. Il peut être retiré en toute sécurité.
                </div>
            `;
        }
    }

    function populateMenuEditSelector() {
        const select = document.getElementById('editMenuSelector');
        const currentVal = select.value;
        select.innerHTML = '<option value="">✨ -- CRÉER UN NOUVEAU PLAT OUBLIÉ --</option>';
        
        for (let day in foodTrucksData) {
            for (let per in foodTrucksData[day]) {
                if (foodTrucksData[day][per].trucks) {
                    foodTrucksData[day][per].trucks.forEach(t => {
                        t.meals.forEach(m => {
                            const opt = document.createElement('option');
                            opt.value = `${day}|||${per}|||${t.name}|||${m.name}`;
                            opt.innerText = `[${day} - ${per}] ${t.name} ➔ ${m.name}`;
                            select.appendChild(opt);
                        });
                    });
                }
            }
        }
        if(currentVal) select.value = currentVal;
    }

    function populateMenuEditFields() {
        const select = document.getElementById('editMenuSelector');
        const logBox = document.getElementById('editMenuStatusLog');
        const listContainer = document.getElementById('editMenuImpactedUsers');
        const btnUpdate = document.getElementById('btnUpdateManual');
        const btnCreate = document.getElementById('btnCreateManual');
        
        logBox.innerHTML = ''; 
        
        if (!select.value) {
            currentEditingMeal = null;
            listContainer.innerHTML = '';
            btnUpdate.style.display = "none";
            btnCreate.style.display = "block";
            
            document.getElementById('editMenuHours').value = "";
            document.getElementById('editMenuTruck').value = "";
            document.getElementById('editMenuPlat').value = "";
            document.getElementById('editMenuPrix').value = "";
            document.getElementById('editMenuComp').value = "";
            return;
        }
        
        btnUpdate.style.display = "block";
        btnCreate.style.display = "none";
        
        const [day, per, truckName, mealName] = select.value.split('|||');
        const block = foodTrucksData[day][per];
        const truck = block.trucks.find(t => t.name === truckName);
        const meal = truck.meals.find(m => m.name === mealName);
        
        currentEditingMeal = { originalDay: day, originalPeriod: per, originalTruck: truckName, originalMealName: mealName };
        
        document.getElementById('editMenuDay').value = day;
        document.getElementById('editMenuPeriod').value = per;
        document.getElementById('editMenuHours').value = block.hours.join('|');
        document.getElementById('editMenuTruck').value = truckName;
        document.getElementById('editMenuType').value = meal.type || "Plat";
        document.getElementById('editMenuPlat').value = meal.name;
        document.getElementById('editMenuPrix').value = meal.prix;
        document.getElementById('editMenuComp').value = meal.composition || "";
        
        const impacted = appVotes.filter(v => v.day === day && v.period === per && v.truckName === truckName && v.mealName === mealName);
        
        if (impacted.length > 0) {
            const uniqueNames = Array.from(new Set(impacted.map(v => v.name)));
            listContainer.innerHTML = `
                <div class="absents-box" style="background: var(--warning-bg); border-color: var(--warning-border); color: var(--warning-text); margin-bottom:1rem; margin-top:0.5rem;">
                    <strong>⚠️ Personnes impactées par ce plat (${uniqueNames.length}) :</strong><br>
                    <span style="font-size:0.85rem;">${uniqueNames.join(', ')}</span><br>
                    <small style="font-style:italic; display:block; margin-top:0.25rem;">Leurs choix suivront automatiquement les modifications d'horaires, de nom ou de camion.</small>
                </div>
            `;
        } else {
            listContainer.innerHTML = `
                <div class="absents-box" style="background: #f0fdf4; border-color: #bbf7d0; color: #166534; margin-bottom:1rem; margin-top:0.5rem;">
                    🎉 Aucun utilisateur n'a commandé ce plat pour le moment.
                </div>
            `;
        }
    }

    function createNewMenuManual() {
        const day = document.getElementById('editMenuDay').value;
        const period = document.getElementById('editMenuPeriod').value;
        const hoursInput = document.getElementById('editMenuHours').value.split('|').map(h => h.trim()).filter(h => h !== "");
        const truckName = document.getElementById('editMenuTruck').value.trim();
        const mealType = document.getElementById('editMenuType').value;
        const mealName = document.getElementById('editMenuPlat').value.trim();
        const price = parseFloat(document.getElementById('editMenuPrix').value) || 0.0;
        const comp = document.getElementById('editMenuComp').value.trim();

        if (!truckName || !mealName || hoursInput.length === 0) {
